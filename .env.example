# hhwl API base · fetch-sources.ts 用
HHWL_API_BASE=https://blog-picker.hhwlnet.com

# 推送目标 · push.ts 用(从 blogpicker settings 表读 push_api_url 填这里)
PUSH_API_URL=

# 推送鉴权 · push.ts 用(从 blogpicker settings 表读 push_api_secret 填这里)· 不 commit!
PUSH_API_SECRET=

# 一次抓多少源(默认 200 · fetch-sources.ts)
FETCH_LIMIT=200

# probe 一次探多少(默认 200)
PROBE_LIMIT=200
PROBE_CONCURRENCY=10

# sitemap 每个源取前 N URL(默认 20)
SITEMAP_URLS_PER_SOURCE=20

# push DRY RUN 模式 · 不真推 · 仅打印
DRY_RUN=1
